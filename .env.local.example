# ---- Claude (required for skill generation) ----
ANTHROPIC_API_KEY=sk-ant-...
# Flagship model. Defaults to claude-mythos-5 (Project Glasswing); if your org isn't
# enrolled it auto-falls-back to claude-fable-5, then claude-opus-4-8 (see /lib/anthropic.ts).
# Override here, e.g. ANTHROPIC_MODEL=claude-fable-5
ANTHROPIC_MODEL=claude-mythos-5

# ---- GitHub (optional: raises API rate limit + reads private repos) ----
GITHUB_TOKEN=ghp_...

# ---- Supabase (auth + Postgres) — Project Settings → API ----
# Public (browser): URL + anon key. Used for Google sign-in, run history, usage reads.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server only — service_role key. REQUIRED for server-side paywall enforcement.
# Bypasses RLS: verifies user JWTs, increments runs, activates plans. NEVER expose to the browser.
# Without it, the paywall is client-side only (not enforced server-side).
SUPABASE_SERVICE_ROLE_KEY=

# ---- Razorpay (payments) ----
# Without these, the paywall "Pay" buttons run in simulated/demo mode (instant unlock, no charge).
# key_id is sent to the browser to open checkout (safe to expose).
# key_secret is SERVER ONLY — signs/verifies orders, never sent to the client.
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=
# Dashboard → Settings → Webhooks. Used to verify payment.captured / order.paid callbacks
# at /api/payments/webhook so plans activate even if the browser closes mid-redirect.
RAZORPAY_WEBHOOK_SECRET=

# ---- Site ----
# Used for absolute OG image URLs. Set to your deployed origin in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3002
