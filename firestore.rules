rules_version = '2';

// Users own their runs. Entitlement (meta/usage) is READ-ONLY to the client — only the
// Admin SDK (server routes) may write runs and activate plans, so a user can't grant
// themselves a plan or reset their run count by writing Firestore directly.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/runs/{runId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /users/{uid}/meta/{document} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // server-only (Admin SDK bypasses rules)
    }
  }
}
