# Express API — all secrets live here (never shipped to the browser).
# Copy to `server/.env` (gitignored) and fill in. Keep values EMPTY in this example.
PORT=8787
# Allow the Vite client origin (dev). Single origin; defaults to allow-all.
CLIENT_ORIGIN=http://localhost:5173

# Claude (required for generation). Format: sk-ant-...
ANTHROPIC_API_KEY=
# Optional model override; defaults to claude-mythos-5 in code.
ANTHROPIC_MODEL=

# GitHub (optional: higher rate limit + private repos)
GITHUB_TOKEN=

# Supabase (server) — service_role enables paywall enforcement.
# URL format: https://YOUR-PROJECT.supabase.co
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Razorpay (payments). Key id format: rzp_test_... / rzp_live_...
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
