# Express API — all secrets live here (never shipped to the browser).
PORT=8787
# Allow the Vite client origin (dev). Comma-less single origin; defaults to allow-all.
CLIENT_ORIGIN=http://localhost:5173

# Claude (required for generation)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-mythos-5

# GitHub (optional: higher rate limit + private repos)
GITHUB_TOKEN=

# Supabase (server) — service_role enables paywall enforcement
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Razorpay (payments)
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
