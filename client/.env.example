# Vite client — only PUBLIC values (shipped to the browser). No secrets here.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=

# Base URL of the Express API. Leave blank in dev (Vite proxies /api → :8787).
# In production set to your deployed API origin, e.g. https://api.yourdomain.com
VITE_API_BASE=
