# Vite client — only PUBLIC values (shipped to the browser). NO secret keys here.
# Only VITE_-prefixed vars are exposed to the frontend by Vite. Copy to client/.env.
# URL format: https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_URL=
# Supabase "anon public" key — RLS-gated, safe for the browser (not a secret).
VITE_SUPABASE_ANON_KEY=

# Base URL of the Express API. Leave blank in dev (Vite proxies /api → :8787).
# In production set to your deployed API origin, e.g. https://api.yourdomain.com
VITE_API_BASE=
